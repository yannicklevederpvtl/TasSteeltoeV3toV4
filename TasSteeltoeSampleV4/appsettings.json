{
  "$schema": "https://steeltoe.io/schema/v4/schema.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Management": {
    "Endpoints": {
      "Actuator": {
        "Exposure": {
          "Include": [ "*" ]
        }
      },
      "Health": {
        "ShowComponents": "Always",
        "ShowDetails": "Always",
        "Readiness": {
          "Enabled": true
        },
        "Liveness": {
          "Enabled": true
        }
      }
    }
  }
}
